{
  "name": "Resident",
  "type": "object",
  "properties": {
    "room": { "type": "string", "description": "Numéro de chambre (ex: 101, 9G, 23P)" },
    "title": { "type": "string", "enum": ["Mme", "Mr", "Me"], "description": "Civilité" },
    "last_name": { "type": "string", "description": "Nom de famille" },
    "first_name": { "type": "string", "description": "Prénom" },
    "date_naissance": { "type": "string", "format": "date", "description": "Date de naissance" },
    "date_entree": { "type": "string", "format": "date", "description": "Date d'entrée dans l'établissement" },
    "floor": { "type": "string", "enum": ["RDC", "1ER"], "description": "Étage" },
    "section": { "type": "string", "enum": ["Long Séjour", "Mapad"], "description": "Section (Long Séjour ou Mapad)" },
    "annotations": { "type": "string", "description": "Infos importantes (DNID, O2, allergies…)" },
    "consignes": { "type": "string", "description": "Consignes journalières" },
    "ta_number": { "type": "number", "description": "Numéro TA" },
    "sort_order": { "type": "number", "description": "Ordre d'affichage dans la liste" },
    "regime_mixe": { "type": "boolean", "description": "Régime mixé" },
    "viande_mixee": { "type": "boolean", "description": "Viande mixée uniquement" },
    "regime_diabetique": { "type": "boolean", "description": "Régime diabétique" },
    "epargne_intestinale": { "type": "boolean", "description": "Épargne intestinale" },
    "allergie_poisson": { "type": "boolean", "description": "Allergie poisson" },
    "traitement_ecrase": { "type": "boolean", "description": "Traitements à écraser" },
    "insuline_matin": { "type": "boolean", "description": "Insuline le matin" },
    "insuline_soir": { "type": "boolean", "description": "Insuline le soir" },
    "anticoagulants": { "type": "boolean", "description": "Traitement anticoagulant" },
    "appel_nuit": { "type": "boolean", "description": "Appel de nuit" },
    "referent": { "type": "string", "description": "Soignant référent du résident" },
    "medecin": { "type": "string", "description": "Médecin traitant" },
    "complement_alimentaire": { "type": "boolean", "description": "Complément alimentaire prescrit" },
    "complement_alimentaire_date": { "type": "string", "format": "date", "description": "Date de début du complément alimentaire" },
    "supplement_types_json": { "type": "string", "description": "JSON contenant les types de suppléments alimentaires" },
    "supplements_json": { "type": "string", "description": "JSON contenant les détails des suppléments alimentaires" }
  },
  "required": ["room", "last_name", "floor", "section"]
}
